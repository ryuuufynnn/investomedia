{
  "version": 2,
  "rewrites": [
    { "source": "/", "destination": "/html/index.html" },
    { "source": "/index.html", "destination": "/html/index.html" },
    { "source": "/payment.html", "destination": "/html/payment.html" },
    { "source": "/download.html", "destination": "/html/download.html" },
    { "source": "/gcash.html", "destination": "/html/gcash.html" },
    { "source": "/paypal.html", "destination": "/html/paypal.html" },
    { "source": "/css/:path*", "destination": "/css/:path*" },
    { "source": "/js/:path*", "destination": "/js/:path*" },
    { "source": "/img/:path*", "destination": "/img/:path*" }
  ]
}
